---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ id }) => id.startsWith('ko/'));
	return posts.map((post) => ({
		params: { slug: post.id.replace(/^ko\//, '') },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
const slug = post.id.replace(/^ko\//, '');
const hasTranslation = (await getCollection('blog')).some((entry) => entry.id === `en/${slug}`);
---

<BlogPost
	{...post.data}
	lang="ko"
	alternatePath={hasTranslation ? `/blog/${slug}/` : undefined}
>
	<Content />
</BlogPost>
