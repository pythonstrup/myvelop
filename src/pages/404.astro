---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`404 · ${SITE_TITLE}`} description="The requested page could not be found." />
		<meta name="robots" content="noindex, follow" />
		<style>
			:global(body) {
				display: grid;
				min-height: 100svh;
				grid-template-columns: minmax(0, 1fr);
				grid-template-rows: auto 1fr auto;
			}
			.not-found {
				display: grid;
				min-width: 0;
				place-items: center;
				padding-block: 5rem;
			}
			.content {
				width: min(100%, 38rem);
				text-align: center;
			}
			.error-code {
				margin: 0 0 0.75rem;
				color: var(--accent);
				font-size: 0.8rem;
				font-weight: 750;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}
			h1 {
				margin: 0;
				font-size: clamp(2.6rem, 9vw, 4.8rem);
				letter-spacing: -0.055em;
				text-wrap: balance;
			}
			.message {
				max-width: 32rem;
				margin: 1.25rem auto 0;
				color: rgb(var(--gray));
				font-size: 1rem;
			}
			.message span {
				display: block;
				margin-top: 0.3rem;
			}
			.actions {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.75rem;
				margin-top: 2rem;
			}
			.actions a {
				display: inline-flex;
				min-height: 44px;
				align-items: center;
				justify-content: center;
				padding: 0 1rem;
				color: rgb(var(--black));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				font-size: 0.9rem;
				font-weight: 650;
				text-decoration: none;
			}
			.actions a:first-child {
				color: var(--accent-foreground);
				background: var(--accent);
				border-color: var(--accent);
			}
			.actions a:hover {
				border-color: var(--accent);
			}
			.actions a:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			@media (max-width: 600px) {
				.not-found {
					padding-block: 3.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="not-found">
			<section class="content">
				<p class="error-code">404 · Not found</p>
				<h1>Page not found.</h1>
				<p class="message">
					The page may have moved or no longer exists.
					<span lang="ko">페이지가 이동했거나 더 이상 존재하지 않습니다.</span>
				</p>
				<nav class="actions" aria-label="Recovery links · 복구 링크">
					<a href="/" data-ko-href="/ko/">Home · 홈</a>
					<a href="/blog/" data-ko-href="/ko/blog/">Blog · 블로그</a>
				</nav>
			</section>
		</main>
		<Footer />
		<script is:inline>
			if (location.pathname === '/ko' || location.pathname.startsWith('/ko/')) {
				document.documentElement.lang = 'ko';
				document.querySelectorAll('[data-ko-href]').forEach((link) => {
					if (link instanceof HTMLAnchorElement && link.dataset.koHref) {
						link.href = link.dataset.koHref;
					}
				});
			}
		</script>
	</body>
</html>
