---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
	return posts.map((post) => ({
		params: { slug: post.id.replace(/^en\//, '') },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
const slug = post.id.replace(/^en\//, '');
const hasTranslation = (await getCollection('blog')).some((entry) => entry.id === `ko/${slug}`);
---

<BlogPost
	{...post.data}
	lang="en"
	alternatePath={hasTranslation ? `/blog/${slug}/` : undefined}
>
	<Content />
</BlogPost>
