---
import BlogList from '../../layouts/BlogList.astro';
import { BLOG_PAGE_SIZE, getBlogPosts } from '../../lib/blog';

const allPosts = await getBlogPosts('en');
---

<BlogList
	posts={allPosts.slice(0, BLOG_PAGE_SIZE)}
	lang="en"
	currentPage={1}
	totalPages={Math.ceil(allPosts.length / BLOG_PAGE_SIZE)}
/>
