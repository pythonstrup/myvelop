---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Lang = 'en' | 'ko';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const copy = {
	en: {
		title: `Page not found · ${SITE_TITLE}`,
		description: 'The requested page could not be found.',
		code: '404 · Not found',
		heading: 'Page not found.',
		message: 'The page may have moved or no longer exists.',
		home: 'Home',
		blog: 'Blog',
	},
	ko: {
		title: `페이지를 찾을 수 없음 · ${SITE_TITLE}`,
		description: '요청한 페이지를 찾을 수 없습니다.',
		code: '404 · 찾을 수 없음',
		heading: '페이지를 찾을 수 없습니다.',
		message: '페이지가 이동했거나 더 이상 존재하지 않습니다.',
		home: '홈',
		blog: '블로그',
	},
}[lang];
const homeHref = lang === 'ko' ? '/ko/' : '/';
const blogHref = lang === 'ko' ? '/ko/blog/' : '/blog/';
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={copy.title}
			description={copy.description}
			alternatePath="/404/"
		/>
		<meta name="robots" content="noindex, follow" />
		<style>
			:global(body) {
				display: grid;
				min-height: 100svh;
				grid-template-columns: minmax(0, 1fr);
				grid-template-rows: auto 1fr auto;
			}
			.not-found {
				display: grid;
				min-width: 0;
				place-items: center;
				padding-block: 5rem;
			}
			.content {
				width: min(100%, 38rem);
				text-align: center;
			}
			.error-code {
				margin: 0 0 0.75rem;
				color: var(--accent);
				font-size: 0.8rem;
				font-weight: 750;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}
			h1 {
				margin: 0;
				font-size: clamp(2.6rem, 9vw, 4.8rem);
				letter-spacing: -0.055em;
				text-wrap: balance;
			}
			.message {
				max-width: 32rem;
				margin: 1.25rem auto 0;
				color: rgb(var(--gray));
				font-size: 1rem;
			}
			.actions {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.75rem;
				margin-top: 2rem;
			}
			.actions a {
				display: inline-flex;
				min-height: 44px;
				align-items: center;
				justify-content: center;
				padding: 0 1rem;
				color: rgb(var(--black));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				font-size: 0.9rem;
				font-weight: 650;
				text-decoration: none;
			}
			.actions a:first-child {
				color: var(--accent-foreground);
				background: var(--accent);
				border-color: var(--accent);
			}
			.actions a:hover {
				border-color: var(--accent);
			}
			.actions a:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			@media (max-width: 600px) {
				.not-found {
					padding-block: 3.5rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="not-found">
			<section class="content">
				<p class="error-code" data-ko-text="404 · 찾을 수 없음">{copy.code}</p>
				<h1 data-ko-text="페이지를 찾을 수 없습니다.">{copy.heading}</h1>
				<p class="message" data-ko-text="페이지가 이동했거나 더 이상 존재하지 않습니다.">
					{copy.message}
				</p>
				<nav class="actions" aria-label={lang === 'ko' ? '복구 링크' : 'Recovery links'}>
					<a href={homeHref} data-ko-href="/ko/" data-ko-text="홈">{copy.home}</a>
					<a href={blogHref} data-ko-href="/ko/blog/" data-ko-text="블로그">{copy.blog}</a>
				</nav>
			</section>
		</main>
		<Footer />
		<script is:inline>
			// A static host serves 404.html for every unknown path. Localize Korean missing URLs in place.
			if (
				document.documentElement.lang !== 'ko' &&
				(location.pathname === '/ko' || location.pathname.startsWith('/ko/'))
			) {
				document.documentElement.lang = 'ko';
				document.title = '페이지를 찾을 수 없음 · pythonstrup';
				const description = document.querySelector('meta[name="description"]');
				if (description) description.setAttribute('content', '요청한 페이지를 찾을 수 없습니다.');
				document.querySelectorAll('[data-ko-text]').forEach((element) => {
					if (element instanceof HTMLElement && element.dataset.koText) {
						element.textContent = element.dataset.koText;
					}
				});
				document.querySelectorAll('[data-ko-href]').forEach((link) => {
					if (link instanceof HTMLAnchorElement && link.dataset.koHref) link.href = link.dataset.koHref;
				});

				const desktopLanguage = document.querySelector('.lang-switch');
				if (desktopLanguage instanceof HTMLAnchorElement) {
					desktopLanguage.href = '/404/';
					desktopLanguage.textContent = 'EN';
					desktopLanguage.setAttribute('aria-label', '영어로 보기');
				}
				const mobileLanguage = document.querySelector('.language-link');
				if (mobileLanguage instanceof HTMLAnchorElement) mobileLanguage.href = '/404/';
			}
		</script>
	</body>
</html>
