---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { lang?: string; alternatePath?: string };

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	socialImage,
	lang = 'en',
	alternatePath,
} = Astro.props;
const backHref = lang === 'ko' ? '/ko/blog' : '/blog';
const backLabel = lang === 'ko' ? '← 목록으로' : '← Back to blog';
const updatedLabel = lang === 'ko' ? '수정됨' : 'Updated';
---

<html lang={lang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			image={socialImage ?? heroImage}
			alternatePath={alternatePath}
		/>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.back {
				display: inline-block;
				margin-bottom: 2rem;
				font-size: 0.9rem;
				color: rgb(var(--gray));
				text-decoration: none;
			}
			.back:hover {
				color: var(--accent);
			}
			.post-header {
				margin-bottom: 2.5rem;
			}
			.post-header h1 {
				margin: 0 0 0.6rem;
				font-size: 2.4rem;
				line-height: 1.2;
				letter-spacing: -0.03em;
			}
			.post-header .meta {
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.post-header .meta .sep {
				margin: 0 0.5em;
				opacity: 0.5;
			}
			.hero-image {
				margin-bottom: 2rem;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 10px;
			}
			.prose {
				color: rgb(var(--gray-dark));
			}
			.prose :global(h2),
			.prose :global(h3) {
				scroll-margin-top: 2rem;
			}
			.prose :global(a) {
				font-weight: 600;
			}
			.prose :global(pre.mermaid) {
				display: flex;
				justify-content: center;
				margin: 2rem 0;
				padding: 1rem;
				background: transparent;
				white-space: pre-wrap;
			}
			.prose :global(pre.mermaid svg) {
				width: auto;
				max-width: 100%;
				height: auto;
			}
			.post-footer {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid rgb(var(--gray-light));
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<a class="back" href={backHref}>{backLabel}</a>
				<header class="post-header">
					<h1 data-pagefind-body>{title}</h1>
					<div class="meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<>
									<span class="sep">·</span>
									<span>
										{updatedLabel} <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
					</div>
				</header>
				{
					heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" priority />
						</div>
					)
				}
				<div class="prose" data-pagefind-body>
					<slot />
				</div>
				<div class="post-footer">
					<Giscus />
				</div>
			</article>
		</main>
		<Footer />

		<script>
			document.querySelectorAll<HTMLPreElement>('article pre').forEach((pre) => {
				if (pre.classList.contains('mermaid') || pre.parentElement?.classList.contains('code-block'))
					return;
				const wrapper = document.createElement('div');
				wrapper.className = 'code-block';
				pre.parentNode?.insertBefore(wrapper, pre);
				wrapper.appendChild(pre);

				const btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'copy-btn';
				btn.textContent = 'Copy';
				btn.addEventListener('click', async () => {
					const code = pre.querySelector('code')?.innerText ?? pre.innerText;
					try {
						await navigator.clipboard.writeText(code);
						btn.textContent = 'Copied';
						btn.classList.add('copied');
						setTimeout(() => {
							btn.textContent = 'Copy';
							btn.classList.remove('copied');
						}, 1500);
					} catch {
						/* clipboard unavailable */
					}
				});
				wrapper.appendChild(btn);
			});

			const diagrams = Array.from(document.querySelectorAll<HTMLPreElement>('pre.mermaid'));
			if (diagrams.length > 0) {
				const sources = new Map(diagrams.map((diagram) => [diagram, diagram.textContent ?? '']));
				const renderedThemes = new Map<HTMLPreElement, boolean>();
				let mermaid: (typeof import('mermaid'))['default'] | undefined;
				let renderQueue = Promise.resolve();

				const renderDiagram = (diagram: HTMLPreElement) => {
					renderQueue = renderQueue.then(async () => {
						const darkMode = document.documentElement.classList.contains('dark');
						if (renderedThemes.get(diagram) === darkMode) return;

						mermaid ??= (await import('mermaid')).default;
						diagram.removeAttribute('data-processed');
						delete diagram.dataset.mermaidError;
						diagram.textContent = sources.get(diagram) ?? '';
						mermaid.initialize({
							startOnLoad: false,
							securityLevel: 'strict',
							theme: darkMode ? 'dark' : 'default',
						});
						await mermaid.run({ nodes: [diagram] });
						renderedThemes.set(diagram, darkMode);

						if (document.documentElement.classList.contains('dark') !== darkMode) {
							void renderDiagram(diagram);
						}
					}).catch((error) => {
						const message = error instanceof Error
							? `${error.name}: ${error.message}`
							: JSON.stringify(error) || String(error);
						console.error(`Unable to render Mermaid diagram. ${message}`);
						renderedThemes.delete(diagram);
						diagram.removeAttribute('data-processed');
						diagram.dataset.mermaidError = message;
						diagram.textContent = sources.get(diagram) ?? '';
					});
					return renderQueue;
				};

				if ('IntersectionObserver' in window) {
					const observer = new IntersectionObserver(
						(entries) => {
							for (const entry of entries) {
								if (!entry.isIntersecting) continue;
								observer.unobserve(entry.target);
								void renderDiagram(entry.target as HTMLPreElement);
							}
						},
						{ rootMargin: '300px' },
					);
					for (const diagram of diagrams) observer.observe(diagram);
				} else {
					for (const diagram of diagrams) void renderDiagram(diagram);
				}

				new MutationObserver(() => {
					for (const diagram of renderedThemes.keys()) void renderDiagram(diagram);
				}).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
			}
		</script>
	</body>
</html>
