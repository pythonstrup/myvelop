---
import ProfileImage from '../assets/profile.jpg';
import AboutHero from '../components/about/AboutHero.astro';
import ExperienceTimeline from '../components/about/ExperienceTimeline.astro';
import FeaturedProject from '../components/about/FeaturedProject.astro';
import ImpactMetrics from '../components/about/ImpactMetrics.astro';
import ResumeSection from '../components/about/ResumeSection.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { getAboutContent, type AboutLocale } from '../data/about';

interface Props {
	lang: AboutLocale;
}

const { lang } = Astro.props;
const content = getAboutContent(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={content.meta.title}
			description={content.meta.description}
			image={ProfileImage}
			alternatePath="/about/"
		/>
		<style>
			.portfolio {
				width: 1080px;
				max-width: calc(100% - 2rem);
				margin: 0 auto;
				padding: 4rem 1rem 6rem;
			}
			.education {
				padding: 1.5rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 18px;
			}
			.education-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1rem;
			}
			.education h3 {
				margin: 0;
				font-size: 1.35rem;
				letter-spacing: -0.025em;
			}
			.period {
				flex: none;
				font-size: 0.875rem;
				font-weight: 600;
				color: rgb(var(--gray));
			}
			.education p {
				margin: 0.45rem 0 0;
				font-size: 1rem;
				color: rgb(var(--gray));
			}
			.education .detail {
				color: var(--accent);
				font-weight: 650;
			}
			.skills {
				display: flex;
				flex-wrap: wrap;
				gap: 0.65rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.skills li {
				padding: 0.45rem 0.75rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: color-mix(in srgb, rgb(var(--gray-light)) 35%, rgb(var(--bg)));
				font-size: 0.9rem;
				font-weight: 600;
				color: rgb(var(--black));
			}
			.double-grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1rem;
			}
			.featured-projects {
				display: grid;
				gap: clamp(1.25rem, 3vw, 2rem);
			}
			.list-card {
				padding: 1.5rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 18px;
			}
			.list-card h3 {
				margin: 0 0 1rem;
				font-size: 1rem;
			}
			.list-card ul {
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.list-card li {
				display: grid;
				grid-template-columns: 3rem 1fr;
				gap: 0.65rem;
				font-size: 0.95rem;
				line-height: 1.55;
				color: rgb(var(--gray));
			}
			.list-card li + li {
				margin-top: 0.75rem;
			}
			.list-card .year {
				font-weight: 700;
				color: var(--accent);
			}

			@media (max-width: 800px) {
				.portfolio {
					padding-top: 2rem;
				}
			}

			@media (max-width: 600px) {
				.portfolio {
					max-width: calc(100% - 1rem);
					padding: 1rem 0.5rem 4rem;
				}
				.education-head {
					align-items: flex-start;
					flex-direction: column;
					gap: 0.25rem;
				}
				.double-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="portfolio">
			<AboutHero content={content.hero} image={ProfileImage} />
			<ImpactMetrics content={content.metrics} />

			<ResumeSection number="01" title={content.projects.label}>
				<div class="featured-projects">
					{content.projects.items.map((project) => <FeaturedProject content={project} />)}
				</div>
			</ResumeSection>

			<ResumeSection number="02" title={content.experience.label} meta={content.experience.meta}>
				<ExperienceTimeline experiences={content.experience.items} />
			</ResumeSection>

			<ResumeSection number="03" title={content.education.label}>
				<article class="education">
					<div class="education-head">
						<h3>{content.education.item.school}</h3>
						<time class="period">{content.education.item.period}</time>
					</div>
					<p>{content.education.item.major}</p>
					<p class="detail">{content.education.item.detail}</p>
				</article>
			</ResumeSection>

			<ResumeSection number="04" title={content.skills.label}>
				<ul class="skills">
					{content.skills.items.map((skill) => <li>{skill}</li>)}
				</ul>
			</ResumeSection>

			<ResumeSection
				number="05"
				title={`${content.activities.label} ${lang === 'ko' ? '·' : '&'} ${content.awards.label}`}
			>
				<div class="double-grid">
					<article class="list-card">
						<h3>{content.activities.label}</h3>
						<ul>
							{
								content.activities.items.map((item) => (
									<li><span class="year">{item.year}</span><span>{item.text}</span></li>
								))
							}
						</ul>
					</article>
					<article class="list-card">
						<h3>{content.awards.label}</h3>
						<ul>
							{
								content.awards.items.map((item) => (
									<li><span class="year">{item.year}</span><span>{item.text}</span></li>
								))
							}
						</ul>
					</article>
				</div>
			</ResumeSection>
		</main>
		<Footer />
	</body>
</html>
