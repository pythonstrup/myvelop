---
const year = new Date().getFullYear();
const isKo = Astro.currentLocale === 'ko';
const tagline = isKo ? '한 걸음씩 쌓아가는 개발 기록.' : 'Development notes, one step at a time.';
const rssHref = isKo ? '/ko/rss.xml' : '/rss.xml';
---

<footer class="site-footer">
	<div class="footer-inner">
		<p>&copy; {year} pythonstrup. <span>{tagline}</span></p>
		<nav aria-label={isKo ? '푸터 링크' : 'Footer links'}>
			<a href="https://github.com/pythonstrup" target="_blank" rel="noreferrer">GitHub</a>
			<a
				href="https://www.linkedin.com/in/%EC%A2%85%ED%98%81-%EB%B0%95-6b062821a/"
				target="_blank"
				rel="noreferrer"
			>LinkedIn</a>
			<a href={rssHref}>RSS</a>
		</nav>
	</div>
</footer>

<style>
	.site-footer {
		color: rgb(var(--gray));
		background: color-mix(in srgb, rgb(var(--gray-light)) 28%, rgb(var(--bg)));
		border-top: 1px solid rgb(var(--gray-light));
	}
	.footer-inner {
		display: flex;
		width: min(calc(100% - 32px), 1120px);
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin: 0 auto;
		padding: 1.25rem 0;
	}
	.footer-inner p {
		margin: 0;
		font-size: 0.82rem;
		line-height: 1.5;
	}
	.footer-inner p span {
		color: rgb(var(--gray-dark));
	}
	.footer-inner nav {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.footer-inner a {
		display: inline-flex;
		min-height: 44px;
		align-items: center;
		padding: 0 0.65rem;
		color: rgb(var(--gray));
		font-size: 0.8rem;
		font-weight: 600;
		text-decoration: none;
	}
	.footer-inner a:hover {
		color: var(--accent);
	}
	.footer-inner a:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
		border-radius: 6px;
	}
	@media (max-width: 600px) {
		.footer-inner {
			width: calc(100% - 24px);
			align-items: flex-start;
			flex-direction: column;
			gap: 0.35rem;
			padding: 1.1rem 0;
		}
		.footer-inner p span {
			display: block;
		}
		.footer-inner nav {
			margin-left: -0.65rem;
		}
	}
</style>
