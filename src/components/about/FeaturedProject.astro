---
import cacheArchitectureUrl from '../../assets/portfolio/cache-architecture.svg?url';
import lohasmealArchitectureUrl from '../../assets/portfolio/lohasmeal-architecture.svg?url';
import notificationArchitectureUrl from '../../assets/portfolio/notification-architecture.svg?url';
import zeppelinArchitectureUrl from '../../assets/portfolio/zeppelin-architecture.svg?url';
import type { AboutFeaturedProjectContent } from '../../data/about';
import ProjectVisual from './ProjectVisual.astro';

interface Props {
	content: AboutFeaturedProjectContent;
}

const { content } = Astro.props;
// Astro dev serves imported source SVGs through Vite's URL route.
const visuals = {
	notification: { url: notificationArchitectureUrl, width: 1700, height: 1800 },
	lohasmeal: { url: lohasmealArchitectureUrl, width: 1600, height: 1100 },
	cache: { url: cacheArchitectureUrl, width: 1600, height: 900 },
	zeppelin: { url: zeppelinArchitectureUrl, width: 800, height: 1080 },
};
const visual = content.visual ? visuals[content.visual.key] : undefined;
const visualSrc = visual && import.meta.env.DEV ? `${visual.url}?url` : visual?.url;
const summaryParagraphs = content.summary.split('\n\n');
const showContextualVisual = content.visual?.key === 'zeppelin' && summaryParagraphs.length > 1;
---

<article class="featured-project">
	<div class="project-copy">
		<p class="eyebrow">{content.eyebrow}</p>
		<h3>{content.title}</h3>
		<div class="summary">
			{
				summaryParagraphs.map((paragraph, index) => (
					<Fragment>
						<p>{paragraph}</p>
						{showContextualVisual && index === 0 && content.visual && visual && visualSrc && (
							<ProjectVisual
								visual={content.visual}
								src={visualSrc}
								width={visual.width}
								height={visual.height}
								contextual
							/>
						)}
					</Fragment>
				))
			}
		</div>

		<ul class="highlights">
			{
				content.highlights.map((highlight) => (
					<li>
						<strong>{highlight.value}</strong>
						<span>{highlight.label}</span>
					</li>
				))
			}
		</ul>

		<ul class="stack">
			{content.stack.map((technology) => <li>{technology}</li>)}
		</ul>

		<div class="project-links">
			{
				content.links.map((link) => (
					<a
						class="project-link"
						href={link.href}
						target={link.external ? '_blank' : undefined}
						rel={link.external ? 'noreferrer' : undefined}
					>
						{link.label}<span aria-hidden="true">{link.external ? '↗' : '→'}</span>
					</a>
				))
			}
		</div>
	</div>

	{content.visual && visual && visualSrc && !showContextualVisual && (
		<ProjectVisual
			visual={content.visual}
			src={visualSrc}
			width={visual.width}
			height={visual.height}
		/>
	)}
</article>

<style>
	.featured-project {
		grid-column: 1 / -1;
		min-width: 0;
		overflow: hidden;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 18px;
		background: rgb(var(--bg));
	}
	.project-copy {
		max-width: 860px;
		padding: clamp(1.35rem, 3vw, 2.25rem);
	}
	.eyebrow {
		margin: 0 0 0.65rem;
		font-size: 0.75rem;
		font-weight: 750;
		letter-spacing: 0.12em;
		color: var(--accent);
	}
	h3 {
		max-width: 34ch;
		margin: 0;
		font-size: clamp(1.65rem, 4vw, 2.6rem);
		line-height: 1.16;
		letter-spacing: -0.045em;
		text-wrap: balance;
		white-space: pre-line;
		word-break: keep-all;
	}
	.summary {
		max-width: 72ch;
		margin: 1rem 0 0;
		font-size: 1rem;
		line-height: 1.75;
		color: rgb(var(--gray));
	}
	.summary p {
		margin: 0;
	}
	.summary p:not(:first-child) {
		margin-top: 0.8rem;
	}
	.highlights {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
		gap: 1px;
		margin: 1.75rem 0 0;
		padding: 0;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		overflow: hidden;
		background: rgb(var(--gray-light));
		list-style: none;
	}
	.highlights li {
		min-width: 0;
		padding: 1rem;
		background: rgb(var(--bg));
	}
	.highlights strong,
	.highlights span {
		display: block;
	}
	.highlights strong {
		font-size: 1.1rem;
		letter-spacing: -0.025em;
		color: rgb(var(--black));
	}
	.highlights span {
		margin-top: 0.3rem;
		font-size: 0.82rem;
		line-height: 1.45;
		color: rgb(var(--gray));
	}
	.stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 1.25rem 0 0;
		padding: 0;
		list-style: none;
	}
	.stack li {
		padding: 0.35rem 0.6rem;
		border-radius: 999px;
		background: color-mix(in srgb, rgb(var(--gray-light)) 55%, rgb(var(--bg)));
		font-size: 0.78rem;
		font-weight: 650;
		color: rgb(var(--gray-dark));
	}
	.project-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem 1rem;
		margin-top: 0.75rem;
	}
	.project-link {
		display: inline-flex;
		min-height: 44px;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.9rem;
		font-weight: 700;
		color: var(--accent);
		text-underline-offset: 0.2em;
	}
	.project-link:hover {
		text-decoration-thickness: 2px;
	}
	.project-link:focus-visible {
		border-radius: 4px;
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}
	@media (max-width: 600px) {
		.featured-project {
			border-radius: 16px;
		}
		.project-copy {
			padding: 1.25rem;
		}
		.highlights {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 480px) {
		h3 {
			white-space: normal;
		}
	}
</style>
