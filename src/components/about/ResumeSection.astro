---
interface Props {
	number: string;
	title: string;
	meta?: string;
}

const { number, title, meta } = Astro.props;
---

<section class="resume-section">
	<header class="section-heading">
		<p class="section-number">{number}</p>
		<h2>{title}</h2>
		{meta && <small>{meta}</small>}
	</header>
	<slot />
</section>

<style>
	.resume-section {
		display: grid;
		grid-template-columns: 170px minmax(0, 1fr);
		gap: 2.5rem;
		padding: 4rem 0;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.section-number {
		margin: 0 0 0.8rem;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.section-heading h2 {
		margin: 0;
		font-size: 1.15rem;
		letter-spacing: -0.02em;
	}
	.section-heading small {
		display: block;
		margin-top: 0.4rem;
		font-size: 0.78rem;
		color: rgb(var(--gray));
	}

	@media (max-width: 800px) {
		.resume-section {
			grid-template-columns: 130px minmax(0, 1fr);
			gap: 1.5rem;
		}
	}

	@media (max-width: 600px) {
		.resume-section {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			padding: 3rem 0;
		}
	}
</style>
