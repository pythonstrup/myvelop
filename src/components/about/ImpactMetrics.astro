---
import type { AboutMetricsContent } from '../../data/about';

interface Props {
	content: AboutMetricsContent;
}

const { content } = Astro.props;
---

<section class="metrics" aria-label={content.label}>
	{
		content.items.map((metric) => (
			<div class="metric">
				<strong>{metric.value}</strong>
				<span>{metric.label}</span>
			</div>
		))
	}
</section>

<style>
	.metrics {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.75rem;
		margin-top: 1rem;
	}
	.metric {
		min-width: 0;
		padding: 1.35rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 18px;
		background: rgb(var(--bg));
	}
	.metric strong {
		display: block;
		margin-bottom: 0.35rem;
		font-size: clamp(1.35rem, 2.5vw, 1.8rem);
		line-height: 1.1;
		letter-spacing: -0.04em;
		color: rgb(var(--black));
	}
	.metric span {
		display: block;
		font-size: 0.9rem;
		line-height: 1.5;
		color: rgb(var(--gray));
	}

	@media (max-width: 800px) {
		.metrics {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 600px) {
		.metrics {
			gap: 0.5rem;
		}
		.metric {
			padding: 1rem;
		}
	}
</style>
