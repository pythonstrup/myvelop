---
import { externalLinks, isActivePath, navLinks } from '../lib/nav';

type Props = {
	currentPath: string;
	isKo: boolean;
	langSwitchHref: string;
};

const { currentPath, isKo, langSwitchHref } = Astro.props;
const links = navLinks(isKo);
const homeHref = isKo ? '/ko' : '/';
const menuId = 'mobile-menu';
---

<button
	type="button"
	class="menu-trigger"
	aria-label={isKo ? '메뉴 열기' : 'Open menu'}
	aria-haspopup="dialog"
	aria-controls={menuId}
	aria-expanded="false"
	data-menu-open
>
	<svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
		<path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
	</svg>
</button>

<dialog id={menuId} class="mobile-menu" aria-label={isKo ? '메인 메뉴' : 'Main menu'}>
	<div class="menu-panel">
		<header class="menu-header">
			<div>
				<p class="menu-kicker">{isKo ? '둘러보기' : 'Navigation'}</p>
				<h2><a href={homeHref}>pythonstrup</a></h2>
			</div>
			<form method="dialog">
				<button type="submit" class="menu-close" aria-label={isKo ? '메뉴 닫기' : 'Close menu'} autofocus>
					<svg width="21" height="21" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
					</svg>
				</button>
			</form>
		</header>

		<nav aria-label={isKo ? '모바일 메뉴' : 'Mobile navigation'} class="menu-links">
			<p class="section-label">{isKo ? '페이지' : 'Pages'}</p>
			{
				links.map((link, index) => {
					const active = isActivePath(currentPath, link.href);
					return (
						<a href={link.href} class:list={['menu-link', { active }]} aria-current={active ? 'page' : undefined}>
							<span class="link-index">{String(index + 1).padStart(2, '0')}</span>
							<span class="link-label">{link.label}</span>
							{active ? (
								<span class="active-dot" aria-hidden="true"></span>
							) : (
								<svg class="link-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
									<path d="m9 18 6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
								</svg>
							)}
						</a>
					);
				})
			}
		</nav>

		<footer class="menu-footer">
			<a class="language-link" href={langSwitchHref}>
				<span class="utility-icon" aria-hidden="true">
					<svg width="19" height="19" viewBox="0 0 24 24" fill="none">
						<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"></circle>
						<path d="M3.5 12h17M12 3c2.2 2.45 3.35 5.45 3.35 9S14.2 18.55 12 21c-2.2-2.45-3.35-5.45-3.35-9S9.8 5.45 12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
					</svg>
				</span>
				<span class="utility-copy">
					<small>{isKo ? '언어' : 'Language'}</small>
					<strong>{isKo ? 'English' : '한국어'}</strong>
				</span>
				<svg class="utility-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="m9 18 6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
				</svg>
			</a>

			<div class="external-links">
				{
					externalLinks.map(({ label, href }) => (
						<a href={href} target="_blank" rel="noreferrer">
							<span>{label}</span>
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
							</svg>
						</a>
					))
				}
			</div>
			<p class="menu-signature">© {new Date().getFullYear()} pythonstrup</p>
		</footer>
	</div>
</dialog>

<script>
	const trigger = document.querySelector<HTMLButtonElement>('[data-menu-open]');
	const dialog = document.getElementById('mobile-menu');

	if (trigger && dialog instanceof HTMLDialogElement) {
		const desktopViewport = window.matchMedia('(min-width: 721px)');

		trigger.addEventListener('click', () => {
			if (dialog.open) return;
			dialog.showModal();
			trigger.setAttribute('aria-expanded', 'true');
			document.documentElement.classList.add('menu-open');
		});

		dialog.addEventListener('click', (event) => {
			if (event.target === dialog) dialog.close();
		});

		// Native dialogs close on Escape. Keep the explicit listener as a
		// lightweight fallback for embedded browsers that suppress that default.
		dialog.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && dialog.open) dialog.close();
		});

		dialog.addEventListener('close', () => {
			trigger.setAttribute('aria-expanded', 'false');
			document.documentElement.classList.remove('menu-open');
			trigger.focus();
		});

		desktopViewport.addEventListener('change', (event) => {
			if (event.matches && dialog.open) dialog.close();
		});
	}
</script>

<style>
	.menu-trigger,
	.menu-close {
		display: inline-flex;
		width: 44px;
		height: 44px;
		align-items: center;
		justify-content: center;
		padding: 0;
		color: rgb(var(--black));
		background: transparent;
		border: 1px solid transparent;
		border-radius: 12px;
		cursor: pointer;
		transition:
			background-color 160ms ease,
			border-color 160ms ease,
			transform 160ms ease;
	}

	.menu-trigger:hover,
	.menu-close:hover {
		background: rgba(var(--gray-light), 0.72);
	}

	.menu-trigger:active,
	.menu-close:active {
		transform: scale(0.94);
	}

	.menu-trigger:focus-visible,
	.menu-close:focus-visible,
	.mobile-menu a:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.mobile-menu {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		max-width: none;
		max-height: none;
		margin: 0;
		padding: 0;
		overflow: hidden;
		background: transparent;
		border: 0;
	}

	.mobile-menu[open] {
		display: block;
	}

	.mobile-menu::backdrop {
		background: rgba(8, 12, 20, 0.48);
		backdrop-filter: blur(3px);
		animation: backdrop-in 180ms ease-out;
	}

	.menu-panel {
		position: absolute;
		inset-block-start: 0;
		inset-inline-end: 0;
		display: flex;
		width: min(88vw, 360px);
		height: 100vh;
		height: 100dvh;
		flex-direction: column;
		overflow-y: auto;
		overscroll-behavior: contain;
		color: rgb(var(--gray-dark));
		background: rgb(var(--bg));
		box-shadow: -24px 0 72px rgba(8, 12, 20, 0.22);
		animation: panel-in 220ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.menu-header {
		display: flex;
		min-height: 72px;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding: max(12px, env(safe-area-inset-top)) 16px 10px 22px;
		border-bottom: 1px solid rgba(var(--gray-light), 0.82);
	}

	.menu-header form {
		margin: 0;
	}

	.menu-kicker,
	.section-label,
	.menu-signature {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.65rem;
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.menu-header h2 {
		margin: 3px 0 0;
		font-size: 1rem;
		line-height: 1.2;
		letter-spacing: -0.035em;
	}

	.menu-header h2 a {
		color: rgb(var(--black));
		text-decoration: none;
	}

	.menu-links {
		display: flex;
		flex-direction: column;
		gap: 6px;
		padding: 22px 16px 18px;
	}

	.section-label {
		padding: 0 8px 7px;
	}

	.menu-link {
		display: grid;
		min-height: 56px;
		grid-template-columns: 34px 1fr 18px;
		align-items: center;
		gap: 8px;
		padding: 0 14px 0 12px;
		color: rgb(var(--gray-dark));
		border-radius: 12px;
		text-decoration: none;
		transition:
			color 160ms ease,
			background-color 160ms ease,
			transform 160ms ease;
	}

	.menu-link:hover {
		color: rgb(var(--black));
		background: rgba(var(--gray-light), 0.6);
		transform: translateX(2px);
	}

	.menu-link.active {
		color: rgb(var(--black));
		font-weight: 700;
		background: rgba(var(--gray-light), 0.66);
		box-shadow: inset 3px 0 0 var(--accent);
	}

	.link-index {
		color: rgb(var(--gray));
		font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
		font-size: 0.64rem;
		font-weight: 600;
		letter-spacing: 0.04em;
	}

	.link-label {
		font-size: 1rem;
		font-weight: 650;
		letter-spacing: -0.02em;
	}

	.link-arrow,
	.utility-arrow {
		color: rgb(var(--gray));
	}

	.active-dot {
		width: 7px;
		height: 7px;
		justify-self: center;
		background: var(--accent);
		border-radius: 999px;
		box-shadow: 0 0 0 4px rgba(var(--gray-light), 0.9);
	}

	.menu-footer {
		margin-top: auto;
		padding: 18px 16px max(18px, env(safe-area-inset-bottom));
		border-top: 1px solid rgba(var(--gray-light), 0.82);
	}

	.language-link {
		display: grid;
		min-height: 58px;
		grid-template-columns: 38px 1fr 18px;
		align-items: center;
		gap: 10px;
		padding: 0 12px;
		color: rgb(var(--gray-dark));
		background: rgba(var(--gray-light), 0.5);
		border: 1px solid rgba(var(--gray-light), 0.9);
		border-radius: 13px;
		text-decoration: none;
		transition: background-color 160ms ease;
	}

	.language-link:hover {
		color: rgb(var(--black));
		background: rgba(var(--gray-light), 0.82);
	}

	.utility-icon {
		display: inline-flex;
		width: 34px;
		height: 34px;
		align-items: center;
		justify-content: center;
		color: rgb(var(--black));
		background: rgb(var(--bg));
		border-radius: 10px;
	}

	.utility-copy {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}

	.utility-copy small {
		color: rgb(var(--gray));
		font-size: 0.62rem;
		font-weight: 650;
		line-height: 1.2;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.utility-copy strong {
		color: rgb(var(--black));
		font-size: 0.82rem;
		line-height: 1.3;
	}

	.external-links {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 8px;
		margin-top: 9px;
	}

	.external-links a {
		display: flex;
		min-height: 44px;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		padding: 0 12px;
		color: rgb(var(--gray-dark));
		border: 1px solid rgba(var(--gray-light), 0.95);
		border-radius: 11px;
		font-size: 0.72rem;
		font-weight: 650;
		text-decoration: none;
		transition:
			color 160ms ease,
			background-color 160ms ease;
	}

	.external-links a:hover {
		color: rgb(var(--black));
		background: rgba(var(--gray-light), 0.55);
	}

	.menu-signature {
		margin-top: 16px;
		padding: 0 2px;
		font-size: 0.56rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: none;
	}

	:global(html.menu-open) {
		overflow: hidden;
	}

	@keyframes panel-in {
		from {
			opacity: 0;
			transform: translateX(12px);
		}
		to {
			opacity: 1;
			transform: translateX(0);
		}
	}

	@keyframes backdrop-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	@media (min-width: 721px) {
		.menu-trigger,
		.mobile-menu {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.menu-panel,
		.mobile-menu::backdrop {
			animation: none;
		}
		.menu-trigger,
		.menu-close,
		.menu-link,
		.language-link,
		.external-links a {
			transition: none;
		}
	}
</style>
